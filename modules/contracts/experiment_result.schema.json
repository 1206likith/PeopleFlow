{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ExperimentResult",
  "type": "object",
  "required": ["config", "config_hash", "metrics", "metadata", "artifacts"],
  "properties": {
    "config": { "type": "object" },
    "config_hash": { "type": "string" },
    "metrics": { "type": "object" },
    "metadata": {
      "type": "object",
      "properties": {
        "generated_at": { "type": "string" },
        "git_commit": { "type": ["string", "null"] },
        "python_version": { "type": "string" },
        "platform": { "type": "string" },
        "hostname": { "type": ["string", "null"] }
      }
    },
    "validation": { "type": "object" },
    "calibration_score": { "type": ["number", "null"] },
    "optimization_score": { "type": ["number", "null"] },
    "artifacts": { "type": "object" }
  }
}
