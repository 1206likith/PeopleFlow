# PeopleFlow Environment Configuration
# Copy this file to .env and update with your values

# Application Settings
APP_NAME=PeopleFlow
DEBUG=False
APP_MODE=demo

# Database Configuration
MONGODB_URL=mongodb://localhost:27017
# For MongoDB Atlas, use:
# MONGODB_URL=mongodb+srv://username:password@cluster.mongodb.net/peopleflow
MONGODB_DB_NAME=peopleflow

# Redis Configuration (Optional)
REDIS_URL=redis://localhost:6379

# Security
# Legacy auth settings (deprecated)
SECRET_KEY=deprecated-not-used
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Admin mutation guard
ADMIN_KEY_ENABLED=True
ADMIN_API_KEY=change-this-admin-key

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://peopleflow.vercel.app,https://peopleflow-ruddy.vercel.app
CORS_ORIGIN_REGEX=^https://peopleflow(?:-[a-z0-9-]+)*\.vercel\.app$

# File Upload
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE=10485760

# Email Configuration (Optional - for SendGrid)
SENDGRID_API_KEY=your-sendgrid-api-key-here
FROM_EMAIL=noreply@peopleflow.com

# Unity WebSocket Bridge
UNITY_WS_URL=ws://localhost:8765
UNITY_ENABLED=False

# AI Models
AI_MODEL_REGISTRY_PATH=modules/ai_engine/data/model_registry.json
AI_CONGESTION_MODEL_PATH=modules/ai_engine/data/saved_models/congestion_predictor.pkl
AI_EXIT_RL_MODEL_PATH=modules/ai_engine/data/saved_models/exit_allocation_rl.pth

# Evacuation Parameters
EVAC_PARAMS_PATH=apps/backend/app/data/evacuation_parameters.json

# Frontend URLs (for CORS and redirects)
FRONTEND_URL=http://localhost:3000

